# Copy to .env.certmagic and fill values.
# Then run:
# docker compose -f deploy/compose/docker-compose.certmagic.yml --env-file deploy/compose/.env.certmagic up -d --build

# Required core settings
CERTMAGIC_DOMAINS=intercom.example.org
CERTMAGIC_EMAIL=ops@example.org
CERTMAGIC_DNS_PROVIDER=cloudflare

# Optional tuning
CERTMAGIC_CA=https://acme-v02.api.letsencrypt.org/directory
CERTMAGIC_PROPAGATION_DELAY_SECONDS=0
CERTMAGIC_PROPAGATION_TIMEOUT_SECONDS=120
CERTMAGIC_DNS_RESOLVERS=1.1.1.1:53,8.8.8.8:53

# Cloudflare example (use API token, not global API key)
CERTMAGIC_CLOUDFLARE_API_TOKEN={{CLOUDFLARE_API_TOKEN}}
# CERTMAGIC_CLOUDFLARE_ZONE_TOKEN={{CLOUDFLARE_ZONE_TOKEN}}

# Hetzner example
# CERTMAGIC_DNS_PROVIDER=hetzner
# CERTMAGIC_HETZNER_API_TOKEN={{HETZNER_API_TOKEN}}

# Route53 example
# CERTMAGIC_DNS_PROVIDER=route53
# CERTMAGIC_ROUTE53_REGION=eu-central-1
# CERTMAGIC_ROUTE53_ACCESS_KEY_ID={{AWS_ACCESS_KEY_ID}}
# CERTMAGIC_ROUTE53_SECRET_ACCESS_KEY={{AWS_SECRET_ACCESS_KEY}}
# CERTMAGIC_ROUTE53_HOSTED_ZONE_ID=Z0123456789ABCDEFG
